#!/bin/sh

# Release environment — evaluated at boot.

# BEAM cluster cookie (all nodes in the cluster must share this)
export RELEASE_COOKIE="${RELEASE_COOKIE:-zoom_gate_dev_cookie}"

# Node name for distributed Erlang
# Use longnames (-name) for cross-host clustering
if [ -n "$RELEASE_NODE" ]; then
  export RELEASE_DISTRIBUTION=name
  export RELEASE_NODE="$RELEASE_NODE"
else
  export RELEASE_DISTRIBUTION=sname
  export RELEASE_NODE=zoom_gate
fi
