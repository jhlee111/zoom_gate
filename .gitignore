# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
zoom_gate-*.tar

# Temporary files, for example, from tests.
/tmp/

# Zoom Meeting SDK (download separately, do not commit)
/native/zoom-meeting-sdk/
/native/build/

# Environment files
.env
.env.*

# OS files
.DS_Store

# Node modules
node_modules/

# Zoom tokens (secrets)
native/.zoom_tokens*.json

# Build artifacts
native/build-*/
native/__pycache__/

# SDK packages (large binaries)
native/zoom-meeting-sdk-*/
native/zoom-meeting-sdk-macos/
native/zoom-web-sdk-analysis/

# Test artifacts
native/web-sdk-test/net_thread_*.min.js
native/web-sdk-test/js_media_original.min.js
native/web-sdk-test/zoomus-patched.umd.min.js

# WebSocket capture files (contain session auth tokens)
native/web-sdk-test/*.jsonl

# Compiled test binaries
native/test_auth

# Scripts with hardcoded paths/credentials
native/run_probe.sh
native/zoom_join_test.py
native/zoom_join_v2.py
native/zoom_probe.py
native/zoom_oauth.py
